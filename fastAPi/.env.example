# DverseAI — FastAPI Backend environment variables
# Copy this file to '.env' inside the fastAPi/app directory.

# Database Connection String
DATABASE_URL=sqlite:///./app.db

# JWT Auth Authentication Details
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Google OAuth Integration
GOOGLE_CLIENT_ID=your-google-oauth-client-id-here

# Groq LLM API Key
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# Chroma Cloud Vector DB Settings
CHROMA_API_KEY=your-chroma-cloud-api-key-here
CHROMA_TENANT=your-chroma-tenant-id-here
CHROMA_DATABASE=ai-pdf-chat
CHROMA_COLLECTION=pdf_chunks

# Upload Limitations & Storage Directory
MAX_FILE_SIZE_MB=20
UPLOAD_DIR=app/uploads
