# ==========================================
# DverseAI — Root Environment Variable Template
# ==========================================

# ----------------------------
# FASTAPI BACKEND CONFIG (.env in fastAPi/app/.env)
# ----------------------------
# Database Connection String (SQLite by default)
DATABASE_URL=sqlite:///./app.db

# JWT Auth Authentication Details
SECRET_KEY=use-a-secure-random-32-hex-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Google OAuth Integration
GOOGLE_CLIENT_ID=your-google-oauth-client-id-here

# Groq LLM API Key (e.g. Llama-3.3-70b-versatile)
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# Chroma Cloud Vector DB Settings
CHROMA_API_KEY=your-chroma-cloud-api-key-here
CHROMA_TENANT=your-chroma-tenant-id-here
CHROMA_DATABASE=ai-pdf-chat
CHROMA_COLLECTION=pdf_chunks

# Upload Limitations & Storage Directory
MAX_FILE_SIZE_MB=20
UPLOAD_DIR=app/uploads

# Hugging Face Serverless Inference API Token (Bypasses PyTorch execution on low-RAM hosts)
HF_TOKEN=your-huggingface-token-here


# ----------------------------
# REACT FRONTEND CONFIG (.env in frontEnd/.env)
# ----------------------------
# Google Sign-In Button Client ID
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id-here

# Backend REST API server URL endpoint
VITE_API_URL=http://localhost:8000
